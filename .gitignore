# === Python Examples (Execution & Cache) ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Node.js / TypeScript Examples ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
out/
coverage/
.next/
.nuxt/

# === Virtual Environments (Avoid committing local venvs) ===
.venv
.venv/
env/
venv/
ENV/

# === Security & Secrets (Zero Trust: Block ALL env files) ===
# Security: Prevent accidental leak of API keys and local secrets
.env
.env.*
!.env.example
.dev.vars
secrets.json
*.pem
*.key

# === Data Artifacts (Local Processing Outputs) ===
# Exclude raw data extractions to keep repo clean
*.csv
*.tsv
*.jsonl
*.parquet
output/
data/
tmp/
downloads/

# === Editor / IDE (Keep repo clean) ===
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.history/

# === Operating System ===
.DS_Store
Thumbs.db
desktop.ini
